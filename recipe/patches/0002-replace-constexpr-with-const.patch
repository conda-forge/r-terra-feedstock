From f1d227bf4b20239faee0136c7b09df8df6ca3f04 Mon Sep 17 00:00:00 2001
From: Daniel Nachun <daniel.nachun@gmail.com>
Date: Sat, 5 Oct 2024 20:34:14 -0700
Subject: [PATCH 2/2] replace constexpr with const

---
 src/NA.h             | 16 ++++++++--------
 src/raster_stats.cpp |  2 +-
 2 files changed, 9 insertions(+), 9 deletions(-)

diff --git a/src/NA.h b/src/NA.h
index 205cde7..a160bca 100644
--- a/src/NA.h
+++ b/src/NA.h
@@ -22,13 +22,13 @@
 template <class T> 
 class NA {
   public:
-    static constexpr T value = std::is_floating_point<T>::value ? NAN : std::numeric_limits<T>::min();
+    static const T value = std::is_floating_point<T>::value ? NAN : std::numeric_limits<T>::min();
 };
 
 // bool has no NA
 template <> class NA<bool> {
 public:
-  static constexpr unsigned value = false;
+  static const unsigned value = false;
 };
 
 template <typename T>
@@ -44,7 +44,7 @@ struct is_string<std::basic_string<T, Traits, Alloc>> {
 /*
 template <> class NAvalue<unsigned> {
 public:
-    static constexpr unsigned value = std::numeric_limits<unsigned>::max();
+    static const unsigned value = std::numeric_limits<unsigned>::max();
 };
 */
 
@@ -60,7 +60,7 @@ bool is_NA(const T v) {
 
 template <> class NA<unsigned> {
 public:
-    static constexpr unsigned value = std::numeric_limits<unsigned>::max();
+    static const unsigned value = std::numeric_limits<unsigned>::max();
 };
 
 
@@ -76,22 +76,22 @@ void set_NA(std::vector<T> &v, double naflag) {
 /*
 class NA_long {
 public:
-    static constexpr long value = std::numeric_limits<long>::min();
+    static const long value = std::numeric_limits<long>::min();
 };
 
 class NA_unsigned {
 public:
-    static constexpr unsigned value = std::numeric_limits<unsigned>::max();
+    static const unsigned value = std::numeric_limits<unsigned>::max();
 };
 
 class NA_double {
 public:
-    static constexpr double value = NAN;
+    static const double value = NAN;
 };
 
 class NA_float {
 public:
-    static constexpr float value = NAN;
+    static const float value = NAN;
 };
 
 
diff --git a/src/raster_stats.cpp b/src/raster_stats.cpp
index d7f291d..9265ffa 100644
--- a/src/raster_stats.cpp
+++ b/src/raster_stats.cpp
@@ -254,7 +254,7 @@ std::vector<std::vector<double>> SpatRaster::unique(bool bylayer, double digits,
 	std::vector<std::vector<double>> out;
 	if (!hasValues()) return out;
 
-	constexpr double lowest_double = std::numeric_limits<double>::lowest();
+	const double lowest_double = std::numeric_limits<double>::lowest();
 
 	BlockSize bs = getBlockSize(opt);
 	unsigned nc = ncol();
-- 
2.45.2

